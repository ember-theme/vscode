{
  "$schema": "vscode://schemas/color-theme",
  "name": "Ember Light",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#282418",
    "variable.declaration": "#282418",
    "variable.readonly": "#946030",
    "parameter": "#585040",
    "property": "#946030",
    "property.declaration": "#946030",
    "property.readonly": "#946030",
    "function": "#7a6820",
    "function.declaration": "#7a6820",
    "method": "#386858",
    "method.declaration": "#386858",
    "type": { "foreground": "#7a6820", "bold": true, "italic": true },
    "type.declaration": { "foreground": "#7a6820", "bold": true, "italic": true },
    "class": { "foreground": "#7a6820", "bold": true, "italic": true },
    "interface": { "foreground": "#7a6820", "italic": true },
    "enum": { "foreground": "#7a6820", "bold": true },
    "enumMember": "#946030",
    "namespace": "#7a6820",
    "keyword": { "foreground": "#b84c30", "bold": true },
    "comment": { "foreground": "#787060", "italic": true },
    "string": "#4a6830",
    "number": "#946030",
    "operator": "#605848",
    "decorator": "#b84c30",
    "macro": "#b84c30"
  },
  "colors": {
    "focusBorder": "#b84c3060",
    "foreground": "#282418",
    "descriptionForeground": "#585040",
    "errorForeground": "#905050",
    "icon.foreground": "#585040",
    "selection.background": "#b8ac9680",

    "editor.background": "#e6dac4",
    "editor.foreground": "#282418",
    "editorCursor.foreground": "#b84c30",
    "editor.selectionBackground": "#d8ccb0",
    "editor.selectionHighlightBackground": "#d8ccb060",
    "editor.inactiveSelectionBackground": "#d8ccb080",
    "editor.lineHighlightBackground": "#ddd0b8",
    "editor.lineHighlightBorder": "#ddd0b800",
    "editor.findMatchBackground": "#b84c3040",
    "editor.findMatchHighlightBackground": "#b84c3025",
    "editor.findMatchBorder": "#b84c30",
    "editor.rangeHighlightBackground": "#ddd0b8",
    "editor.wordHighlightBackground": "#d8ccb060",
    "editor.wordHighlightStrongBackground": "#d8ccb080",
    "editorLink.activeForeground": "#b84c30",

    "editorLineNumber.foreground": "#989080",
    "editorLineNumber.activeForeground": "#b84c30",
    "editorIndentGuide.background": "#cec2a8",
    "editorIndentGuide.activeBackground": "#b8ac96",
    "editorRuler.foreground": "#cec2a8",
    "editorBracketMatch.background": "#d8ccb060",
    "editorBracketMatch.border": "#989080",

    "editorWhitespace.foreground": "#cec2a8",
    "editorError.foreground": "#905050",
    "editorWarning.foreground": "#7a6820",
    "editorInfo.foreground": "#3a6080",
    "editorHint.foreground": "#386858",

    "editorGutter.addedBackground": "#4a6830",
    "editorGutter.modifiedBackground": "#7a6820",
    "editorGutter.deletedBackground": "#b84c30",

    "editorOverviewRuler.errorForeground": "#905050",
    "editorOverviewRuler.warningForeground": "#7a6820",
    "editorOverviewRuler.infoForeground": "#3a6080",
    "editorOverviewRuler.modifiedForeground": "#7a6820",
    "editorOverviewRuler.addedForeground": "#4a6830",
    "editorOverviewRuler.deletedForeground": "#b84c30",
    "editorOverviewRuler.border": "#e6dac4",

    "editorWidget.background": "#ddd0b8",
    "editorWidget.foreground": "#282418",
    "editorWidget.border": "#b8ac96",
    "editorSuggestWidget.background": "#ddd0b8",
    "editorSuggestWidget.foreground": "#282418",
    "editorSuggestWidget.selectedBackground": "#d8ccb0",
    "editorSuggestWidget.highlightForeground": "#b84c30",
    "editorSuggestWidget.focusHighlightForeground": "#b84c30",
    "editorHoverWidget.background": "#ddd0b8",
    "editorHoverWidget.border": "#b8ac96",

    "editorGroup.border": "#b8ac96",
    "editorGroupHeader.tabsBackground": "#ddd0b8",
    "editorGroupHeader.noTabsBackground": "#e6dac4",

    "tab.activeBackground": "#e6dac4",
    "tab.activeForeground": "#282418",
    "tab.activeBorderTop": "#b84c30",
    "tab.inactiveBackground": "#ddd0b8",
    "tab.inactiveForeground": "#787060",
    "tab.border": "#ddd0b8",

    "activityBar.background": "#ddd0b8",
    "activityBar.foreground": "#282418",
    "activityBar.inactiveForeground": "#989080",
    "activityBar.border": "#cec2a8",
    "activityBar.activeBorder": "#b84c30",
    "activityBarBadge.background": "#b84c30",
    "activityBarBadge.foreground": "#e6dac4",

    "sideBar.background": "#ddd0b8",
    "sideBar.foreground": "#585040",
    "sideBar.border": "#cec2a8",
    "sideBarTitle.foreground": "#282418",
    "sideBarSectionHeader.background": "#e6dac4",
    "sideBarSectionHeader.foreground": "#282418",

    "list.activeSelectionBackground": "#d8ccb0",
    "list.activeSelectionForeground": "#b84c30",
    "list.hoverBackground": "#cec2a8",
    "list.hoverForeground": "#282418",
    "list.inactiveSelectionBackground": "#d8ccb0",
    "list.inactiveSelectionForeground": "#282418",
    "list.highlightForeground": "#b84c30",
    "list.focusBackground": "#d8ccb0",
    "list.focusForeground": "#282418",

    "tree.indentGuidesStroke": "#cec2a8",

    "statusBar.background": "#e6dac4",
    "statusBar.foreground": "#585040",
    "statusBar.border": "#cec2a8",
    "statusBar.debuggingBackground": "#b84c30",
    "statusBar.debuggingForeground": "#e6dac4",
    "statusBar.noFolderBackground": "#e6dac4",
    "statusBar.noFolderForeground": "#585040",
    "statusBarItem.hoverBackground": "#d8ccb0",
    "statusBarItem.remoteBackground": "#b84c30",
    "statusBarItem.remoteForeground": "#e6dac4",

    "titleBar.activeBackground": "#ddd0b8",
    "titleBar.activeForeground": "#282418",
    "titleBar.inactiveBackground": "#ddd0b8",
    "titleBar.inactiveForeground": "#989080",
    "titleBar.border": "#cec2a8",

    "input.background": "#f0e8d8",
    "input.foreground": "#282418",
    "input.border": "#b8ac96",
    "input.placeholderForeground": "#989080",
    "inputOption.activeBorder": "#b84c30",
    "inputOption.activeBackground": "#b84c3020",
    "inputValidation.errorBackground": "#e0c8c0",
    "inputValidation.errorBorder": "#905050",
    "inputValidation.warningBackground": "#ddd0a8",
    "inputValidation.warningBorder": "#7a6820",
    "inputValidation.infoBackground": "#c8d0d8",
    "inputValidation.infoBorder": "#3a6080",

    "dropdown.background": "#f0e8d8",
    "dropdown.foreground": "#282418",
    "dropdown.border": "#b8ac96",

    "button.background": "#b84c30",
    "button.foreground": "#e6dac4",
    "button.hoverBackground": "#a04028",
    "button.secondaryBackground": "#d8ccb0",
    "button.secondaryForeground": "#282418",
    "button.secondaryHoverBackground": "#cec2a8",

    "badge.background": "#b84c30",
    "badge.foreground": "#e6dac4",

    "scrollbar.shadow": "#00000015",
    "scrollbarSlider.background": "#b8ac9650",
    "scrollbarSlider.hoverBackground": "#b8ac9680",
    "scrollbarSlider.activeBackground": "#989080",

    "progressBar.background": "#b84c30",

    "panel.background": "#e6dac4",
    "panel.border": "#cec2a8",
    "panelTitle.activeBorder": "#b84c30",
    "panelTitle.activeForeground": "#282418",
    "panelTitle.inactiveForeground": "#787060",

    "terminal.background": "#e6dac4",
    "terminal.foreground": "#282418",
    "terminalCursor.foreground": "#b84c30",
    "terminal.ansiBlack": "#e6dac4",
    "terminal.ansiRed": "#b84c30",
    "terminal.ansiGreen": "#4a6830",
    "terminal.ansiYellow": "#7a6820",
    "terminal.ansiBlue": "#3a6080",
    "terminal.ansiMagenta": "#905050",
    "terminal.ansiCyan": "#386858",
    "terminal.ansiWhite": "#282418",
    "terminal.ansiBrightBlack": "#b8ac96",
    "terminal.ansiBrightRed": "#b84c30",
    "terminal.ansiBrightGreen": "#4a6830",
    "terminal.ansiBrightYellow": "#7a6820",
    "terminal.ansiBrightBlue": "#3a6080",
    "terminal.ansiBrightMagenta": "#905050",
    "terminal.ansiBrightCyan": "#386858",
    "terminal.ansiBrightWhite": "#282418",

    "breadcrumb.foreground": "#787060",
    "breadcrumb.focusForeground": "#282418",
    "breadcrumb.activeSelectionForeground": "#b84c30",
    "breadcrumbPicker.background": "#ddd0b8",

    "gitDecoration.addedResourceForeground": "#4a6830",
    "gitDecoration.modifiedResourceForeground": "#7a6820",
    "gitDecoration.deletedResourceForeground": "#b84c30",
    "gitDecoration.untrackedResourceForeground": "#4a6830",
    "gitDecoration.ignoredResourceForeground": "#989080",
    "gitDecoration.conflictingResourceForeground": "#905050",

    "diffEditor.insertedTextBackground": "#4a683020",
    "diffEditor.removedTextBackground": "#90505020",
    "diffEditor.insertedLineBackground": "#4a683015",
    "diffEditor.removedLineBackground": "#90505015",

    "peekView.border": "#b84c30",
    "peekViewEditor.background": "#f0e8d8",
    "peekViewEditor.matchHighlightBackground": "#b84c3040",
    "peekViewResult.background": "#e6dac4",
    "peekViewResult.fileForeground": "#282418",
    "peekViewResult.lineForeground": "#585040",
    "peekViewResult.matchHighlightBackground": "#b84c3040",
    "peekViewResult.selectionBackground": "#d8ccb0",
    "peekViewResult.selectionForeground": "#282418",
    "peekViewTitle.background": "#ddd0b8",
    "peekViewTitleLabel.foreground": "#282418",
    "peekViewTitleDescription.foreground": "#787060",

    "merge.currentHeaderBackground": "#4a683040",
    "merge.currentContentBackground": "#4a683020",
    "merge.incomingHeaderBackground": "#3a608040",
    "merge.incomingContentBackground": "#3a608020",

    "minimap.findMatchHighlight": "#b84c3060",
    "minimap.selectionHighlight": "#d8ccb0",
    "minimap.errorHighlight": "#905050",
    "minimap.warningHighlight": "#7a6820",

    "notificationCenterHeader.background": "#ddd0b8",
    "notifications.background": "#ddd0b8",
    "notifications.foreground": "#282418",
    "notifications.border": "#b8ac96",
    "notificationsErrorIcon.foreground": "#905050",
    "notificationsWarningIcon.foreground": "#7a6820",
    "notificationsInfoIcon.foreground": "#3a6080",

    "quickInput.background": "#ddd0b8",
    "quickInput.foreground": "#282418",
    "quickInputTitle.background": "#d8ccb0",
    "quickInputList.focusBackground": "#d8ccb0",
    "quickInputList.focusForeground": "#282418",

    "settings.headerForeground": "#282418",
    "settings.modifiedItemIndicator": "#b84c30",
    "settings.focusedRowBackground": "#ddd0b8",

    "keybindingLabel.background": "#d8ccb0",
    "keybindingLabel.foreground": "#282418",
    "keybindingLabel.border": "#b8ac96",
    "keybindingLabel.bottomBorder": "#b8ac96"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#787060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comment",
      "scope": ["comment.block.documentation", "comment.block.javadoc"],
      "settings": {
        "foreground": "#605848",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b84c30",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operator",
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#605848",
        "fontStyle": ""
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#7a6820"
      }
    },
    {
      "name": "Method",
      "scope": [
        "entity.name.function.member",
        "meta.function-call.method"
      ],
      "settings": {
        "foreground": "#386858"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#4a6830"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#946030"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#7a6820",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Interface / Enum",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#7a6820",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#946030",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#282418"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#585040"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "entity.name.tag.yaml",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#946030"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#605848"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.bracket",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#585040"
      }
    },
    {
      "name": "Builtin",
      "scope": [
        "support.function.builtin",
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#b84c30",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Preprocessor / Decorator",
      "scope": [
        "meta.preprocessor",
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#b84c30"
      }
    },
    {
      "name": "Tag (HTML/XML)",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#b84c30"
      }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#946030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#282418"
      }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#946030"
      }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#b84c30",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.type.module"],
      "settings": {
        "foreground": "#7a6820"
      }
    },
    {
      "name": "Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#b84c30",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#b84c30",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bold",
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#946030"
      }
    },
    {
      "name": "Markdown list",
      "scope": ["markup.list", "punctuation.definition.list"],
      "settings": {
        "foreground": "#b84c30"
      }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#4a6830"
      }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#b84c30"
      }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#7a6820"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#386858"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#905050"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#989080",
        "fontStyle": "strikethrough"
      }
    }
  ]
}
