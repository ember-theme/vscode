{
  "$schema": "vscode://schemas/color-theme",
  "name": "Ember",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#d8d0c0",
    "variable.declaration": "#d8d0c0",
    "variable.readonly": "#c09058",
    "parameter": "#b0a898",
    "property": "#c09058",
    "property.declaration": "#c09058",
    "property.readonly": "#c09058",
    "function": "#c8b468",
    "function.declaration": "#c8b468",
    "method": "#80a090",
    "method.declaration": "#80a090",
    "type": { "foreground": "#c8b468", "bold": true, "italic": true },
    "type.declaration": { "foreground": "#c8b468", "bold": true, "italic": true },
    "class": { "foreground": "#c8b468", "bold": true, "italic": true },
    "interface": { "foreground": "#c8b468", "italic": true },
    "enum": { "foreground": "#c8b468", "bold": true },
    "enumMember": "#c09058",
    "namespace": "#c8b468",
    "keyword": { "foreground": "#e08060", "bold": true },
    "comment": { "foreground": "#706c61", "italic": true },
    "string": "#8a9868",
    "number": "#c09058",
    "operator": "#908a7e",
    "decorator": "#e08060",
    "macro": "#e08060"
  },
  "colors": {
    "focusBorder": "#3e3c3800",
    "foreground": "#d8d0c0",
    "descriptionForeground": "#b0a898",
    "errorForeground": "#b07878",
    "icon.foreground": "#b0a898",
    "selection.background": "#3e3c3880",

    "editor.background": "#1c1b19",
    "editor.foreground": "#d8d0c0",
    "editorCursor.foreground": "#e08060",
    "editor.selectionBackground": "#3e3c38",
    "editor.selectionHighlightBackground": "#3e3c3860",
    "editor.inactiveSelectionBackground": "#3e3c3880",
    "editor.lineHighlightBackground": "#242320",
    "editor.lineHighlightBorder": "#24232000",
    "editor.findMatchBackground": "#e0806050",
    "editor.findMatchHighlightBackground": "#e0806030",
    "editor.findMatchBorder": "#e08060",
    "editor.rangeHighlightBackground": "#242320",
    "editor.wordHighlightBackground": "#3e3c3860",
    "editor.wordHighlightStrongBackground": "#3e3c3880",
    "editorLink.activeForeground": "#e08060",

    "editorLineNumber.foreground": "#585550",
    "editorLineNumber.activeForeground": "#e08060",
    "editorIndentGuide.background": "#2e2d2a",
    "editorIndentGuide.activeBackground": "#3e3c38",
    "editorRuler.foreground": "#2e2d2a",
    "editorBracketMatch.background": "#3e3c3860",
    "editorBracketMatch.border": "#706c61",

    "editorWhitespace.foreground": "#2e2d2a",
    "editorError.foreground": "#b07878",
    "editorWarning.foreground": "#c8b468",
    "editorInfo.foreground": "#7890a0",
    "editorHint.foreground": "#80a090",

    "editorGutter.addedBackground": "#8a9868",
    "editorGutter.modifiedBackground": "#c8b468",
    "editorGutter.deletedBackground": "#e08060",

    "editorOverviewRuler.errorForeground": "#b07878",
    "editorOverviewRuler.warningForeground": "#c8b468",
    "editorOverviewRuler.infoForeground": "#7890a0",
    "editorOverviewRuler.modifiedForeground": "#c8b468",
    "editorOverviewRuler.addedForeground": "#8a9868",
    "editorOverviewRuler.deletedForeground": "#e08060",
    "editorOverviewRuler.border": "#1c1b19",

    "editorWidget.background": "#252422",
    "editorWidget.foreground": "#d8d0c0",
    "editorWidget.border": "#3e3c38",
    "editorSuggestWidget.background": "#252422",
    "editorSuggestWidget.foreground": "#d8d0c0",
    "editorSuggestWidget.selectedBackground": "#3e3c38",
    "editorSuggestWidget.highlightForeground": "#e08060",
    "editorSuggestWidget.focusHighlightForeground": "#e08060",
    "editorHoverWidget.background": "#252422",
    "editorHoverWidget.border": "#3e3c38",

    "editorGroup.border": "#3e3c38",
    "editorGroupHeader.tabsBackground": "#151412",
    "editorGroupHeader.noTabsBackground": "#1c1b19",

    "tab.activeBackground": "#1c1b19",
    "tab.activeForeground": "#d8d0c0",
    "tab.activeBorderTop": "#e08060",
    "tab.inactiveBackground": "#151412",
    "tab.inactiveForeground": "#706c61",
    "tab.border": "#151412",

    "activityBar.background": "#151412",
    "activityBar.foreground": "#d8d0c0",
    "activityBar.inactiveForeground": "#585550",
    "activityBar.border": "#2e2d2a",
    "activityBar.activeBorder": "#e08060",
    "activityBarBadge.background": "#e08060",
    "activityBarBadge.foreground": "#1c1b19",

    "sideBar.background": "#151412",
    "sideBar.foreground": "#b0a898",
    "sideBar.border": "#2e2d2a",
    "sideBarTitle.foreground": "#d8d0c0",
    "sideBarSectionHeader.background": "#1c1b19",
    "sideBarSectionHeader.foreground": "#d8d0c0",

    "list.activeSelectionBackground": "#3e3c38",
    "list.activeSelectionForeground": "#e08060",
    "list.hoverBackground": "#2e2d2a",
    "list.hoverForeground": "#d8d0c0",
    "list.inactiveSelectionBackground": "#2e2d2a",
    "list.inactiveSelectionForeground": "#d8d0c0",
    "list.highlightForeground": "#e08060",
    "list.focusBackground": "#3e3c38",
    "list.focusForeground": "#d8d0c0",

    "tree.indentGuidesStroke": "#2e2d2a",

    "statusBar.background": "#1c1b19",
    "statusBar.foreground": "#b0a898",
    "statusBar.border": "#2e2d2a",
    "statusBar.debuggingBackground": "#e08060",
    "statusBar.debuggingForeground": "#1c1b19",
    "statusBar.noFolderBackground": "#1c1b19",
    "statusBar.noFolderForeground": "#b0a898",
    "statusBarItem.hoverBackground": "#2e2d2a",
    "statusBarItem.remoteBackground": "#e08060",
    "statusBarItem.remoteForeground": "#1c1b19",

    "titleBar.activeBackground": "#151412",
    "titleBar.activeForeground": "#d8d0c0",
    "titleBar.inactiveBackground": "#151412",
    "titleBar.inactiveForeground": "#585550",
    "titleBar.border": "#2e2d2a",

    "input.background": "#252422",
    "input.foreground": "#d8d0c0",
    "input.border": "#3e3c38",
    "input.placeholderForeground": "#585550",
    "inputOption.activeBorder": "#e08060",
    "inputOption.activeBackground": "#e0806030",
    "inputValidation.errorBackground": "#322927",
    "inputValidation.errorBorder": "#b07878",
    "inputValidation.warningBackground": "#363225",
    "inputValidation.warningBorder": "#c8b468",
    "inputValidation.infoBackground": "#232528",
    "inputValidation.infoBorder": "#7890a0",

    "dropdown.background": "#252422",
    "dropdown.foreground": "#d8d0c0",
    "dropdown.border": "#3e3c38",

    "button.background": "#e08060",
    "button.foreground": "#1c1b19",
    "button.hoverBackground": "#c8704e",
    "button.secondaryBackground": "#3e3c38",
    "button.secondaryForeground": "#d8d0c0",
    "button.secondaryHoverBackground": "#585550",

    "badge.background": "#e08060",
    "badge.foreground": "#1c1b19",

    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#3e3c3860",
    "scrollbarSlider.hoverBackground": "#3e3c3890",
    "scrollbarSlider.activeBackground": "#585550",

    "progressBar.background": "#e08060",

    "panel.background": "#1c1b19",
    "panel.border": "#2e2d2a",
    "panelTitle.activeBorder": "#e08060",
    "panelTitle.activeForeground": "#d8d0c0",
    "panelTitle.inactiveForeground": "#706c61",

    "terminal.background": "#1c1b19",
    "terminal.foreground": "#d8d0c0",
    "terminalCursor.foreground": "#e08060",
    "terminal.ansiBlack": "#1c1b19",
    "terminal.ansiRed": "#e08060",
    "terminal.ansiGreen": "#8a9868",
    "terminal.ansiYellow": "#c8b468",
    "terminal.ansiBlue": "#7890a0",
    "terminal.ansiMagenta": "#b07878",
    "terminal.ansiCyan": "#80a090",
    "terminal.ansiWhite": "#d8d0c0",
    "terminal.ansiBrightBlack": "#3e3c38",
    "terminal.ansiBrightRed": "#e08060",
    "terminal.ansiBrightGreen": "#8a9868",
    "terminal.ansiBrightYellow": "#c8b468",
    "terminal.ansiBrightBlue": "#7890a0",
    "terminal.ansiBrightMagenta": "#b07878",
    "terminal.ansiBrightCyan": "#80a090",
    "terminal.ansiBrightWhite": "#d8d0c0",

    "breadcrumb.foreground": "#706c61",
    "breadcrumb.focusForeground": "#d8d0c0",
    "breadcrumb.activeSelectionForeground": "#e08060",
    "breadcrumbPicker.background": "#252422",

    "gitDecoration.addedResourceForeground": "#8a9868",
    "gitDecoration.modifiedResourceForeground": "#c8b468",
    "gitDecoration.deletedResourceForeground": "#e08060",
    "gitDecoration.untrackedResourceForeground": "#8a9868",
    "gitDecoration.ignoredResourceForeground": "#585550",
    "gitDecoration.conflictingResourceForeground": "#b07878",

    "diffEditor.insertedTextBackground": "#8a986815",
    "diffEditor.removedTextBackground": "#b0787815",
    "diffEditor.insertedLineBackground": "#8a986810",
    "diffEditor.removedLineBackground": "#b0787810",

    "peekView.border": "#e08060",
    "peekViewEditor.background": "#151412",
    "peekViewEditor.matchHighlightBackground": "#e0806040",
    "peekViewResult.background": "#1c1b19",
    "peekViewResult.fileForeground": "#d8d0c0",
    "peekViewResult.lineForeground": "#b0a898",
    "peekViewResult.matchHighlightBackground": "#e0806040",
    "peekViewResult.selectionBackground": "#3e3c38",
    "peekViewResult.selectionForeground": "#d8d0c0",
    "peekViewTitle.background": "#252422",
    "peekViewTitleLabel.foreground": "#d8d0c0",
    "peekViewTitleDescription.foreground": "#706c61",

    "merge.currentHeaderBackground": "#8a986840",
    "merge.currentContentBackground": "#8a986820",
    "merge.incomingHeaderBackground": "#7890a040",
    "merge.incomingContentBackground": "#7890a020",

    "minimap.findMatchHighlight": "#e0806060",
    "minimap.selectionHighlight": "#3e3c38",
    "minimap.errorHighlight": "#b07878",
    "minimap.warningHighlight": "#c8b468",

    "notificationCenterHeader.background": "#252422",
    "notifications.background": "#252422",
    "notifications.foreground": "#d8d0c0",
    "notifications.border": "#3e3c38",
    "notificationsErrorIcon.foreground": "#b07878",
    "notificationsWarningIcon.foreground": "#c8b468",
    "notificationsInfoIcon.foreground": "#7890a0",

    "quickInput.background": "#252422",
    "quickInput.foreground": "#d8d0c0",
    "quickInputTitle.background": "#2e2d2a",
    "quickInputList.focusBackground": "#3e3c38",
    "quickInputList.focusForeground": "#d8d0c0",

    "settings.headerForeground": "#d8d0c0",
    "settings.modifiedItemIndicator": "#e08060",
    "settings.focusedRowBackground": "#2e2d2a",

    "keybindingLabel.background": "#2e2d2a",
    "keybindingLabel.foreground": "#d8d0c0",
    "keybindingLabel.border": "#3e3c38",
    "keybindingLabel.bottomBorder": "#3e3c38"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#706c61",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comment",
      "scope": ["comment.block.documentation", "comment.block.javadoc"],
      "settings": {
        "foreground": "#908a7e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#e08060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword operator",
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": {
        "foreground": "#908a7e",
        "fontStyle": ""
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#c8b468"
      }
    },
    {
      "name": "Method",
      "scope": [
        "entity.name.function.member",
        "meta.function-call.method"
      ],
      "settings": {
        "foreground": "#80a090"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#8a9868"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#c09058"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#c8b468",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Interface / Enum",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#c8b468",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c09058",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#d8d0c0"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#b0a898"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "entity.name.tag.yaml",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#c09058"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#908a7e"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.bracket",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#b0a898"
      }
    },
    {
      "name": "Builtin",
      "scope": [
        "support.function.builtin",
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#e08060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Preprocessor / Decorator",
      "scope": [
        "meta.preprocessor",
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#e08060"
      }
    },
    {
      "name": "Tag (HTML/XML)",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#e08060"
      }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#c09058",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#d8d0c0"
      }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#c09058"
      }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#e08060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.type.module"],
      "settings": {
        "foreground": "#c8b468"
      }
    },
    {
      "name": "Link",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#e08060",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#e08060",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bold",
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#c09058"
      }
    },
    {
      "name": "Markdown list",
      "scope": ["markup.list", "punctuation.definition.list"],
      "settings": {
        "foreground": "#e08060"
      }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#8a9868"
      }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e08060"
      }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#c8b468"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#80a090"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#b07878"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#585550",
        "fontStyle": "strikethrough"
      }
    }
  ]
}
